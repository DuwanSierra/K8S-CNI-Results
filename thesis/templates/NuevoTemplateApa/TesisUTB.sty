\renewcommand{\nomgroup}[1]{%
\ifthenelse{\equal{#1}{V}}{\vspace{1cm} \item[\bfseries \large Variables]}{}
\ifthenelse{\equal{#1}{X}}{\item[\bfseries \normalsize Variables binarias]}{}
\ifthenelse{\equal{#1}{Y}}{\item[\bfseries \normalsize Variables continuas]}{}
\ifthenelse{\equal{#1}{C}}{\vspace{1cm} \item[\bfseries \large Conjuntos]}{}
\ifthenelse{\equal{#1}{F}}{\vspace{2cm} \item[\bfseries \large Funciones]}{}
\ifthenelse{\equal{#1}{P}}{\vspace{1cm} \item[\bfseries \large Par\'ametros y Sub\'indices]}{}
\ifthenelse{\equal{#1}{A}}{\item[\bfseries \large Abreviaciones]}{}
}	

